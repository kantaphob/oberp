generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 👑 หมวด ALPHA & OMEGA (Core Structure & RBAC)
// ============================================================================
model Service {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("core_services")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  description  String?
  isActive     Boolean       @default(true)
  roles        JobRole[]
  userProfiles UserProfile[]

  @@map("core_departments")
}

model JobLine {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  roles       JobRole[]

  @@map("core_job_lines")
}

model JobRole {
  id          String  @id @default(uuid())
  name        String  @unique
  prefix      String  @unique
  level       Int     @default(10)
  description String?
  isActive    Boolean @default(true)

  departmentId String?
  jobLineId    String?

  // --- ระบบลำดับชั้น (Hierarchy) ---
  parentRoleId String? // ID ของตำแหน่งหัวหน้า

  parentRole     JobRole?  @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  assistantRoles JobRole[] @relation("RoleHierarchy")

  department   Department?   @relation(fields: [departmentId], references: [id])
  jobLine      JobLine?      @relation(fields: [jobLineId], references: [id])
  permissions  Permission[]
  userProfiles UserProfile[]
  users        User[]

  @@map("core_job_roles")
}

model Permission {
  id        String  @id @default(uuid())
  roleId    String
  menuId    String
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)
  role      JobRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("core_permissions")
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  email        String?    @unique
  status       UserStatus @default(ACTIVE)
  roleId       String

  profile UserProfile?
  role    JobRole      @relation(fields: [roleId], references: [id])

  // Relations การทำธุรกรรมต่างๆ
  attendances      Attendance[]
  projects         Project[]         @relation("ProjectManager")
  tasks            Task[]            @relation("TaskAssignee")
  leaveRequests    LeaveRequest[]
  purchaseRequests PurchaseRequest[] @relation("PRRequester")

  // 🌟 แก้ไข: จัดการ Relation ของ BOQ ให้ถูกต้อง (คนสร้าง กับ คนอนุมัติ)
  boqsCreated  BOQ[] @relation("BOQCreator")
  boqsApproved BOQ[] @relation("BOQApprover")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_users")
}

model UserProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate   DateTime?
  gender      String?
  nationality String?

  taxId           String  @unique @db.VarChar(13)
  firstName       String
  lastName        String
  telephoneNumber String  @unique @db.VarChar(10)
  lineId          String?

  addressDetail String
  subdistrictId Int?
  districtId    Int?
  provinceId    Int?
  zipcode       String? @db.VarChar(5)

  departmentId String
  roleId       String
  image        String?

  department  Department   @relation(fields: [departmentId], references: [id])
  role        JobRole      @relation(fields: [roleId], references: [id])
  province    Province?    @relation(fields: [provinceId], references: [id])
  district    District?    @relation(fields: [districtId], references: [id])
  subdistrict Subdistrict? @relation(fields: [subdistrictId], references: [id])

  startDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_user_profiles")
}

// ============================================================================
// 📍 หมวด MASTER DATA (ข้อมูลที่อยู่ประเทศไทย)
// ============================================================================

model Province {
  id           Int           @id
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  districts    District[]
  userProfiles UserProfile[]

  @@map("provinces")
}

model District {
  id         Int      @id
  provinceId Int      @map("province_id")
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  subdistricts Subdistrict[]
  userProfiles UserProfile[]

  @@map("districts")
}

model Subdistrict {
  id         Int      @id
  districtId Int      @map("district_id")
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  lat          Float?
  lng          Float?        @map("long")
  zipcode      Int?
  userProfiles UserProfile[]

  @@map("subdistricts")
}

// ============================================================================
// 📏 หมวด ESTIMATION & COST CONTROL (BOQ, WBS, Materials)
// ============================================================================

model Unit {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true)

  materials MaterialCatalog[]
  boqItems  BOQItem[]

  @@map("est_units")
}

model WBSGroup {
  id   String @id @default(uuid())
  code String @unique
  name String

  parentId String?
  parent   WBSGroup?  @relation("WBSHierarchy", fields: [parentId], references: [id])
  children WBSGroup[] @relation("WBSHierarchy")

  isActive Boolean @default(true)

  boqItems BOQItem[]

  @@map("est_wbs_groups")
}

model MaterialCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  materials MaterialCatalog[]

  @@map("est_material_categories")
}

model MaterialCatalog {
  id    String  @id @default(uuid())
  code  String  @unique
  name  String
  brand String?

  categoryId String?
  category   MaterialCategory? @relation(fields: [categoryId], references: [id])

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  costType   CostType @default(MATERIAL)
  unitPrice  Float    @default(0)
  laborPrice Float    @default(0)

  isActive Boolean @default(true)

  boqItems BOQItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("est_material_catalogs")
}

// ============================================================================
// 👥 หมวด HRM (บุคคลและการเข้างาน)
// ============================================================================

model Attendance {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date        DateTime       @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  type        AttendanceType @default(PRESENT)
  locationLat Float?
  locationLng Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🌟 แก้ไข: ลบโค้ด BOQ ที่ไม่เกี่ยวข้องกันออกไปแล้ว

  @@map("hrm_attendances")
}

model LeaveRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      LeaveType   @default(PERSONAL_LEAVE)
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String
  status    LeaveStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_leave_requests")
}

// ============================================================================
// 🏗️ หมวด OPERATIONS (ระบบโปรเจกต์และงานหน้าไซต์)
// ============================================================================

model Project {
  id       String        @id @default(uuid())
  code     String        @unique
  name     String
  location String?
  status   ProjectStatus @default(PLANNING)

  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  tasks            Task[]
  siteReports      DailySiteReport[]
  purchaseRequests PurchaseRequest[]

  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  boqs BOQ[]

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  projectType   ProjectType? @relation(fields: [projectTypeId], references: [id])
  projectTypeId String?

  @@map("ops_projects")
}

model ProjectType {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  projects    Project[]

  @@map("ops_project_types")
}

model Task {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title  String
  status TaskStatus @default(TODO)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("ops_tasks")
}

model DailySiteReport {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  reportDate  DateTime @db.Date
  weather     String?
  workerCount Int      @default(0)
  progress    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ops_daily_site_reports")
}

model BOQ {
  id         String         @id @default(uuid())
  boqNumber  String         @unique
  version    Int            @default(1)
  status     DocumentStatus @default(DRAFT)
  isApproved Boolean        @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  creatorId  String?
  creator    User?   @relation("BOQCreator", fields: [creatorId], references: [id])
  approverId String?
  approver   User?   @relation("BOQApprover", fields: [approverId], references: [id])

  remarks String?

  items BOQItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🌟 แก้ไข: ลบข้อมูลฟิลด์ที่เบิ้ลและโยงผิดตาราง (Attendance, User ซ้ำ) ออกหมดแล้ว

  @@map("est_boqs")
}

model BOQItem {
  id    String @id @default(uuid())
  boqId String
  boq   BOQ    @relation(fields: [boqId], references: [id], onDelete: Cascade)

  wbsId String
  wbs   WBSGroup @relation(fields: [wbsId], references: [id])

  materialId     String?
  material       MaterialCatalog? @relation(fields: [materialId], references: [id])
  customItemName String?

  qty Float // ปริมาณที่ใช้

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  materialPrice Float
  laborPrice    Float

  totalMaterial Float @default(0)
  totalLabor    Float @default(0)
  totalAmount   Float @default(0)

  remark String?

  @@map("est_boq_items")
}

// ============================================================================
// 🛒 หมวด PROCUREMENT (จัดซื้อและคลังสินค้า)
// ============================================================================

model PurchaseRequest {
  id       String         @id @default(uuid())
  prNumber String         @unique
  status   DocumentStatus @default(DRAFT)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  requesterId String
  requester   User   @relation("PRRequester", fields: [requesterId], references: [id])

  items   Json
  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pro_purchase_requests")
}

// ============================================================================
// 💼 หมวด CRM & SALES (ข้อมูลลูกค้าและประเภทโครงการ)
// ============================================================================
model Customer {
  id            String  @id @default(uuid())
  customerCode  String  @unique
  name          String
  taxId         String? @db.VarChar(13)
  contactPerson String?
  telephone     String
  email         String?
  addressDetail String?

  subdistrictId Int?
  districtId    Int?
  provinceId    Int?
  zipcode       String? @db.VarChar(5)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("crm_customers")
}

// ============================================================================
// 🔴 ENUMS (สถานะทั้งหมดในระบบ)
// ============================================================================

enum UserStatus {
  ACTIVE // ใช้งาน
  INACTIVE // ไม่ใช้งาน
  SUSPENDED // ระงับ
  ON_LEAVE // ลา
  RESIGNED // ลาออก
  TERMINATED // ถูกสิ้นสุด
  LOCKED // ถูกล็อก
  PENDING // รอ
}

enum AttendanceType {
  PRESENT // 
  LATE // สาย
  ABSENT // ขาด
  LEAVE // ลา
  HALFDAY // ครึ่งวัน
  OVERTIME // ล่วงเวลา
  HOLIDAY // หยุด
  WFH // ทำงานบ้าน
  ONSITE // ทำงานที่สถานที่
}

enum LeaveType {
  SICK_LEAVE
  PERSONAL_LEAVE
  ANNUAL_LEAVE
  MATERNITY
  ORDINATION
  UNPAID_LEAVE
}

enum LeaveStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ProjectStatus {
  BIDDING
  PLANNING
  IN_PROGRESS
  ON_HOLD
  HANDOVER
  WARRANTY
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  REWORK
  DONE
}

enum DefectStatus {
  REPORTED
  INSPECTING
  FIXING
  RESOLVED
  REJECTED
  CLOSED
}

enum DocumentStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  REVISED
  REJECTED
  ORDERING
  PARTIAL_RECEIVED
  COMPLETED
  CANCELLED
}

enum CostType {
  MATERIAL // (M) ค่าวัสดุ
  LABOR // (L) ค่าแรงช่าง/พนักงาน
  EQUIPMENT // (E) ค่าเครื่องจักร/เครื่องมือ
  SUBCONTRACTOR // (S) ค่าจ้างเหมาช่วง (รวมของ+แรง)
  SERVICE // (F) ค่าบริการ/ค่าดำเนินการ/ที่ปรึกษา
}
