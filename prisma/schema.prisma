generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ServiceUs {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]

  @@map("core_services")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  description  String?
  isActive     Boolean       @default(true)
  roles        JobRole[]
  userProfiles UserProfile[]

  @@map("core_departments")
}

model JobLine {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  description String?
  isActive    Boolean   @default(true)
  roles       JobRole[]

  @@map("core_job_lines")
}

model JobRole {
  id             String        @id @default(uuid())
  name           String        @unique
  prefix         String        @unique
  level          Int           @default(10)
  departmentId   String?
  jobLineId      String?
  parentRoleId   String?
  description    String?
  isActive       Boolean       @default(true)
  department     Department?   @relation(fields: [departmentId], references: [id])
  jobLine        JobLine?      @relation(fields: [jobLineId], references: [id])
  parentRole     JobRole?      @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  assistantRoles JobRole[]     @relation("RoleHierarchy")
  permissions    Permission[]
  userProfiles   UserProfile[]
  users          User[]

  @@map("core_job_roles")
}

model Permission {
  id        String  @id @default(uuid())
  roleId    String
  menuId    String
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)
  role      JobRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("core_permissions")
}

model User {
  id               String            @id @default(uuid())
  username         String            @unique
  passwordHash     String
  email            String?           @unique
  status           UserStatus        @default(PENDING)
  roleId           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  approvedById     String?
  createdById      String?
  profile          UserProfile?
  approvedBy       User?             @relation("UserApprover", fields: [approvedById], references: [id])
  usersApproved    User[]            @relation("UserApprover")
  createdBy        User?             @relation("UserCreator", fields: [createdById], references: [id])
  usersCreated     User[]            @relation("UserCreator")
  role             JobRole           @relation(fields: [roleId], references: [id])
  boqsApproved     BOQ[]             @relation("BOQApprover")
  boqsCreated      BOQ[]             @relation("BOQCreator")
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  projects         Project[]         @relation("ProjectManager")
  tasks            Task[]            @relation("TaskAssignee")
  purchaseRequests PurchaseRequest[] @relation("PRRequester")
  activityLogs     ActivityLog[]

  requestedActions PendingAction[] @relation("Requester")
  approvedActions  PendingAction[] @relation("Approver")

  @@map("core_users")
}

model UserProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  taxId           String  @unique @db.VarChar(13)
  firstName       String
  lastName        String
  telephoneNumber String  @unique @db.VarChar(10)
  lineId          String?
  gender          String?
  nationality     String?

  addressDetail String
  subdistrictId Int?
  subdistrict   Subdistrict? @relation(fields: [subdistrictId], references: [id])
  districtId    Int?
  district      District?    @relation(fields: [districtId], references: [id])
  departmentId  String
  department    Department   @relation(fields: [departmentId], references: [id])
  provinceId    Int?
  province      Province?    @relation(fields: [provinceId], references: [id])
  zipcode       String?      @db.VarChar(5)

  roleId String
  role   JobRole @relation(fields: [roleId], references: [id])

  image String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  birthDate DateTime?

  startDate DateTime           @default(now())
  file      userProfilesFile[]

  @@map("core_user_profiles")
}

model userProfilesFile {
  id            String      @id @default(uuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade) // 🌟 1. เพิ่ม onDelete: Cascade

  file     String // URL หรือ Path ที่เก็บไฟล์
  fileName String? // ชื่อไฟล์ต้นฉบับ เช่น "บัตรปชช_สมชาย.pdf"

  category     String // 🌟 2. หมวดหมู่หลัก (เช่น "PERSONAL", "EDUCATION", "PROFESSIONAL", "FINANCE")
  documentType String // ประเภทเอกสารย่อย เช่น "ID_CARD", "RESUME", "LICENSE_ENG"

  expireDate DateTime? // วันหมดอายุ (สำหรับ ใบ กว., ใบขับขี่, จป.)

  // 🌟 3. ระบบสถานะการตรวจสอบเอกสาร (HR Verification)
  isVerified Boolean @default(false) // ตรวจสอบความถูกต้องแล้วหรือยัง?
  remark     String? // หมายเหตุจาก HR (เช่น "ภาพไม่ชัด รบกวนอัปโหลดใหม่")

  // 🌟 4. ระบบ Audit Trail (ประทับเวลา)
  createdAt DateTime @default(now()) // อัปโหลดเมื่อไหร่
  updatedAt DateTime @updatedAt // อัปเดตไฟล์ล่าสุดเมื่อไหร่

  @@map("core_user_profiles_files")
}

model PendingAction {
  id          String   @id @default(uuid())
  action      String // e.g., "DELETE_USER", "UPDATE_USER", "DELETE_ROLE"
  description String
  payload     Json // Data to apply
  targetModel String // e.g., "User", "JobRole"
  targetId    String?
  requesterId String
  approverId  String? // The supervisor who authorized the staging
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User  @relation("Requester", fields: [requesterId], references: [id])
  approver  User? @relation("Approver", fields: [approverId], references: [id])

  @@map("sys_pending_actions")
}

model Province {
  id           Int           @id
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  userProfiles UserProfile[]
  districts    District[]

  @@map("provinces")
}

model District {
  id           Int           @id
  provinceId   Int           @map("province_id")
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  userProfiles UserProfile[]
  province     Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  subdistricts Subdistrict[]

  @@map("districts")
}

model Subdistrict {
  id           Int           @id
  districtId   Int           @map("district_id")
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  lat          Float?
  lng          Float?        @map("long")
  zipcode      Int?
  userProfiles UserProfile[]
  district     District      @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@map("subdistricts")
}

model Unit {
  id        String            @id @default(uuid())
  name      String            @unique
  isActive  Boolean           @default(true)
  boqItems  BOQItem[]
  materials MaterialCatalog[]

  @@map("est_units")
}

model WBSGroup {
  id       String     @id @default(uuid())
  code     String     @unique
  name     String
  parentId String?
  isActive Boolean    @default(true)
  boqItems BOQItem[]
  parent   WBSGroup?  @relation("WBSHierarchy", fields: [parentId], references: [id])
  children WBSGroup[] @relation("WBSHierarchy")

  @@map("est_wbs_groups")
}

model MaterialCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  isActive    Boolean           @default(true)
  materials   MaterialCatalog[]

  @@map("est_material_categories")
}

model MaterialCatalog {
  id         String            @id @default(uuid())
  code       String            @unique
  name       String
  brand      String?
  categoryId String?
  unitId     String
  unitPrice  Float             @default(0)
  laborPrice Float             @default(0)
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  costType   CostType          @default(MATERIAL)
  boqItems   BOQItem[]
  category   MaterialCategory? @relation(fields: [categoryId], references: [id])
  unit       Unit              @relation(fields: [unitId], references: [id])

  @@map("est_material_catalogs")
}

model Attendance {
  id          String         @id @default(uuid())
  userId      String
  date        DateTime       @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  type        AttendanceType @default(PRESENT)
  locationLat Float?
  locationLng Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hrm_attendances")
}

model LeaveRequest {
  id        String      @id @default(uuid())
  userId    String
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  type      LeaveType   @default(PERSONAL_LEAVE)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hrm_leave_requests")
}

model Project {
  id               String            @id @default(uuid())
  code             String            @unique
  name             String
  location         String?
  status           ProjectStatus     @default(PLANNING)
  managerId        String?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customerId       String?
  projectTypeId    String?
  serviceUsId      String?
  boqs             BOQ[]
  siteReports      DailySiteReport[]
  customer         Customer?         @relation(fields: [customerId], references: [id])
  manager          User?             @relation("ProjectManager", fields: [managerId], references: [id])
  projectType      ProjectType?      @relation(fields: [projectTypeId], references: [id])
  serviceUs        ServiceUs?        @relation(fields: [serviceUsId], references: [id])
  tasks            Task[]
  purchaseRequests PurchaseRequest[]

  @@map("ops_projects")
}

model ProjectType {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  projects    Project[]

  @@map("ops_project_types")
}

model Task {
  id         String     @id @default(uuid())
  projectId  String
  title      String
  status     TaskStatus @default(TODO)
  assigneeId String?
  dueDate    DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  assignee   User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ops_tasks")
}

model DailySiteReport {
  id          String   @id @default(uuid())
  projectId   String
  reportDate  DateTime @db.Date
  weather     String?
  workerCount Int      @default(0)
  progress    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ops_daily_site_reports")
}

model BOQ {
  id         String         @id @default(uuid())
  boqNumber  String         @unique
  version    Int            @default(1)
  status     DocumentStatus @default(DRAFT)
  isApproved Boolean        @default(false)
  projectId  String
  creatorId  String?
  approverId String?
  remarks    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  items      BOQItem[]
  approver   User?          @relation("BOQApprover", fields: [approverId], references: [id])
  creator    User?          @relation("BOQCreator", fields: [creatorId], references: [id])
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("est_boqs")
}

model BOQItem {
  id             String           @id @default(uuid())
  boqId          String
  wbsId          String
  materialId     String?
  customItemName String?
  qty            Float
  unitId         String
  materialPrice  Float
  laborPrice     Float
  totalMaterial  Float            @default(0)
  totalLabor     Float            @default(0)
  totalAmount    Float            @default(0)
  remark         String?
  boq            BOQ              @relation(fields: [boqId], references: [id], onDelete: Cascade)
  material       MaterialCatalog? @relation(fields: [materialId], references: [id])
  unit           Unit             @relation(fields: [unitId], references: [id])
  wbs            WBSGroup         @relation(fields: [wbsId], references: [id])

  @@map("est_boq_items")
}

model PurchaseRequest {
  id          String         @id @default(uuid())
  prNumber    String         @unique
  status      DocumentStatus @default(DRAFT)
  items       Json
  remarks     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  projectId   String
  requesterId String
  project     Project        @relation(fields: [projectId], references: [id])
  requester   User           @relation("PRRequester", fields: [requesterId], references: [id])

  @@map("pro_purchase_requests")
}

model Customer {
  id            String    @id @default(uuid())
  customerCode  String    @unique
  name          String
  taxId         String?   @db.VarChar(13)
  contactPerson String?
  telephone     String
  email         String?
  addressDetail String?
  subdistrictId Int?
  districtId    Int?
  provinceId    Int?
  zipcode       String?   @db.VarChar(5)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]

  @@map("crm_customers")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE 
  RESIGNED
  TERMINATED
  LOCKED
  PENDING
}

enum AttendanceType {
  PRESENT
  LATE
  ABSENT
  LEAVE
  HALFDAY
  OVERTIME
  HOLIDAY
  WFH
  ONSITE
}

enum LeaveType {
  SICK_LEAVE
  PERSONAL_LEAVE
  ANNUAL_LEAVE
  MATERNITY
  ORDINATION
  UNPAID_LEAVE
}

enum LeaveStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ProjectStatus {
  BIDDING
  PLANNING
  IN_PROGRESS
  ON_HOLD
  HANDOVER
  WARRANTY
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  REWORK
  DONE
}

enum DefectStatus {
  REPORTED
  INSPECTING
  FIXING
  RESOLVED
  REJECTED
  CLOSED
}

enum DocumentStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  REVISED
  REJECTED
  ORDERING
  PARTIAL_RECEIVED
  COMPLETED
  CANCELLED
}

enum CostType {
  MATERIAL
  LABOR
  EQUIPMENT
  SUBCONTRACTOR
  SERVICE
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String // e.g., "USER_LOGIN", "CREATE_DOCUMENT"
  description String
  userId      String?
  roleName    String?
  ipAddress   String?
  status      String   @default("SUCCESS") // "SUCCESS", "FAILED", "WARNING"
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("sys_activity_logs")
}
