generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ServiceUs {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]

  @@map("core_services")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  description  String?
  isActive     Boolean       @default(true)
  roles        JobRole[]
  userProfiles UserProfile[]

  @@map("core_departments")
}

model JobLine {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  description String?
  isActive    Boolean   @default(true)
  roles       JobRole[]

  @@map("core_job_lines")
}

model JobRole {
  id             String        @id @default(uuid())
  name           String        @unique
  prefix         String        @unique
  level          Int           @default(10)
  departmentId   String?
  jobLineId      String?
  parentRoleId   String?
  description    String?
  minSalary      Float?
  maxSalary      Float?
  startingSalary Float?        @default(0)
  defaultPaymentType PayType @default(MONTHLY)
  isActive       Boolean       @default(true)
  department     Department?   @relation(fields: [departmentId], references: [id])
  jobLine        JobLine?      @relation(fields: [jobLineId], references: [id])
  parentRole     JobRole?      @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  assistantRoles JobRole[]     @relation("RoleHierarchy")
  permissions    Permission[]
  userProfiles   UserProfile[]
  users          User[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt

  @@map("core_job_roles")
}

model Permission {
  id        String  @id @default(uuid())
  roleId    String
  menuId    String
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)
  role      JobRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("core_permissions")
}

model User {
  id              String     @id @default(uuid())
  username        String     @unique
  passwordHash    String
  email           String?    @unique
  status          UserStatus @default(PENDING)
  roleId          String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  approvedById    String?
  createdById     String?
  hasProfile      Boolean    @default(false)
  hasProfileFiles Boolean    @default(false)

  teamId   String?
  team     ConstructionTeam?  @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeams ConstructionTeam[] @relation("TeamLeader")

  profile UserProfile?
  role    JobRole      @relation(fields: [roleId], references: [id])

  approvedBy    User?  @relation("UserApprover", fields: [approvedById], references: [id])
  usersApproved User[] @relation("UserApprover")
  createdBy     User?  @relation("UserCreator", fields: [createdById], references: [id])
  usersCreated  User[] @relation("UserCreator")

  boqsApproved     BOQ[]             @relation("BOQApprover")
  boqsCreated      BOQ[]             @relation("BOQCreator")
  projects         Project[]         @relation("ProjectManager")
  tasks            Task[]            @relation("TaskAssignee")
  purchaseRequests PurchaseRequest[] @relation("PRRequester")
  activityLogs     ActivityLog[]
  approvedActions  PendingAction[]   @relation("Approver")
  requestedActions PendingAction[]   @relation("Requester")

  // 🌟 ส่วนที่ปรับปรุงเรื่องกะงานและเวลาเข้าออก
  workShiftId String?
  workShift   WorkShift? @relation("UserShift", fields: [workShiftId], references: [id])

  leaveRequests LeaveRequest[] @relation("UserLeaveRequests")

  attendances       Attendance[] @relation("UserAttendance")
  recordedForOthers Attendance[] @relation("RecordedBy")

  workSchedules   WorkSchedule[]
  otRequests      OtRequest[]      @relation("UserOTRequests")
  approvedOTs     OtRequest[]      @relation("OTApprover")
  hrDocuments     hrDocument[]     @relation("UserDocuments")
  hrDocumentFiles hrDocumentFile[] @relation("UserFiles")
  uploadedFiles   hrDocumentFile[] @relation("DocumentUploader")

  employeeCompensation EmployeeCompensation?
  salaryAdjustments    SalaryAdjustment[]    @relation("UserSalaryHistory")
  approvedSalaries     SalaryAdjustment[]    @relation("SalaryApprover")
  payrollDeductions    PayrollDeduction[]
  earnings             PayrollEarning[]
  payslips             Payslip[]

  @@map("core_users")
}

model UserProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  taxId           String             @unique @db.VarChar(13)
  firstName       String
  lastName        String
  telephoneNumber String             @unique @db.VarChar(10)
  lineId          String?
  addressDetail   String
  subdistrictId   Int?
  districtId      Int?
  provinceId      Int?
  zipcode         String?            @db.VarChar(5)
  departmentId    String
  roleId          String
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  birthDate       DateTime?
  gender          String?
  nationality     String?
  startDate       DateTime           @default(now())
  department      Department         @relation(fields: [departmentId], references: [id])
  district        District?          @relation(fields: [districtId], references: [id])
  province        Province?          @relation(fields: [provinceId], references: [id])
  role            JobRole            @relation(fields: [roleId], references: [id])
  subdistrict     Subdistrict?       @relation(fields: [subdistrictId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
  file            userProfilesFile[]

  @@map("core_user_profiles")
}

model userProfilesFile {
  id            String      @id @default(uuid())
  userProfileId String
  file          String
  fileName      String?
  category      String
  documentType  String
  expireDate    DateTime?
  isVerified    Boolean     @default(false)
  remark        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@map("core_user_profiles_files")
}

model ConstructionTeam {
  id          String     @id @default(uuid())
  name        String
  description String?
  status      TeamStatus @default(ACTIVE)
  leaderId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  leader      User?      @relation("TeamLeader", fields: [leaderId], references: [id])
  members     User[]     @relation("TeamMembers")

  @@map("core_construction_teams")
}

model PendingAction {
  id          String   @id @default(uuid())
  action      String
  description String
  payload     Json
  targetModel String
  targetId    String?
  requesterId String
  approverId  String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  approver    User?    @relation("Approver", fields: [approverId], references: [id])
  requester   User     @relation("Requester", fields: [requesterId], references: [id])

  @@map("sys_pending_actions")
}

model Province {
  id           Int           @id
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  userProfiles UserProfile[]
  districts    District[]

  @@map("provinces")
}

model District {
  id           Int           @id
  provinceId   Int           @map("province_id")
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  userProfiles UserProfile[]
  province     Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  subdistricts Subdistrict[]

  @@map("districts")
}

model Subdistrict {
  id           Int           @id
  districtId   Int           @map("district_id")
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  lat          Float?
  lng          Float?        @map("long")
  zipcode      Int?
  userProfiles UserProfile[]
  district     District      @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@map("subdistricts")
}

model Unit {
  id        String            @id @default(uuid())
  name      String            @unique
  isActive  Boolean           @default(true)
  boqItems  BOQItem[]
  materials MaterialCatalog[]

  @@map("est_units")
}

model WBSGroup {
  id       String     @id @default(uuid())
  code     String     @unique
  name     String
  parentId String?
  isActive Boolean    @default(true)
  boqItems BOQItem[]
  parent   WBSGroup?  @relation("WBSHierarchy", fields: [parentId], references: [id])
  children WBSGroup[] @relation("WBSHierarchy")

  @@map("est_wbs_groups")
}

model MaterialCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  isActive    Boolean           @default(true)
  materials   MaterialCatalog[]

  @@map("est_material_categories")
}

model MaterialCatalog {
  id         String            @id @default(uuid())
  code       String            @unique
  name       String
  brand      String?
  categoryId String?
  unitId     String
  unitPrice  Float             @default(0)
  laborPrice Float             @default(0)
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  costType   CostType          @default(MATERIAL)
  boqItems   BOQItem[]
  category   MaterialCategory? @relation(fields: [categoryId], references: [id])
  unit       Unit              @relation(fields: [unitId], references: [id])

  @@map("est_material_catalogs")
}

model Project {
  id               String            @id @default(uuid())
  code             String            @unique
  name             String
  location         String?
  status           ProjectStatus     @default(PLANNING)
  managerId        String?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customerId       String?
  projectTypeId    String?
  serviceUsId      String?
  boqs             BOQ[]
  siteReports      DailySiteReport[]
  customer         Customer?         @relation(fields: [customerId], references: [id])
  manager          User?             @relation("ProjectManager", fields: [managerId], references: [id])
  projectType      ProjectType?      @relation(fields: [projectTypeId], references: [id])
  serviceUs        ServiceUs?        @relation(fields: [serviceUsId], references: [id])
  tasks            Task[]
  purchaseRequests PurchaseRequest[]

  @@map("ops_projects")
}

model ProjectType {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  projects    Project[]

  @@map("ops_project_types")
}

model Task {
  id         String     @id @default(uuid())
  projectId  String
  title      String
  status     TaskStatus @default(TODO)
  assigneeId String?
  dueDate    DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  assignee   User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ops_tasks")
}

model DailySiteReport {
  id          String   @id @default(uuid())
  projectId   String
  reportDate  DateTime @db.Date
  weather     String?
  workerCount Int      @default(0)
  progress    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ops_daily_site_reports")
}

model BOQ {
  id         String         @id @default(uuid())
  boqNumber  String         @unique
  version    Int            @default(1)
  status     DocumentStatus @default(DRAFT)
  isApproved Boolean        @default(false)
  projectId  String
  creatorId  String?
  approverId String?
  remarks    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  items      BOQItem[]
  approver   User?          @relation("BOQApprover", fields: [approverId], references: [id])
  creator    User?          @relation("BOQCreator", fields: [creatorId], references: [id])
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("est_boqs")
}

model BOQItem {
  id             String           @id @default(uuid())
  boqId          String
  wbsId          String
  materialId     String?
  customItemName String?
  qty            Float
  unitId         String
  materialPrice  Float
  laborPrice     Float
  totalMaterial  Float            @default(0)
  totalLabor     Float            @default(0)
  totalAmount    Float            @default(0)
  remark         String?
  boq            BOQ              @relation(fields: [boqId], references: [id], onDelete: Cascade)
  material       MaterialCatalog? @relation(fields: [materialId], references: [id])
  unit           Unit             @relation(fields: [unitId], references: [id])
  wbs            WBSGroup         @relation(fields: [wbsId], references: [id])

  @@map("est_boq_items")
}

model PurchaseRequest {
  id          String         @id @default(uuid())
  prNumber    String         @unique
  status      DocumentStatus @default(DRAFT)
  items       Json
  remarks     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  projectId   String
  requesterId String
  project     Project        @relation(fields: [projectId], references: [id])
  requester   User           @relation("PRRequester", fields: [requesterId], references: [id])

  @@map("pro_purchase_requests")
}

model Customer {
  id            String    @id @default(uuid())
  customerCode  String    @unique
  name          String
  taxId         String?   @db.VarChar(13)
  contactPerson String?
  telephone     String
  email         String?
  addressDetail String?
  subdistrictId Int?
  districtId    Int?
  provinceId    Int?
  zipcode       String?   @db.VarChar(5)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]

  @@map("crm_customers")
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  description String
  userId      String?
  roleName    String?
  ipAddress   String?
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@map("sys_activity_logs")
}

// 🌟 ตารางการลางาน (เปลี่ยนชื่อเป็น PascalCase ตามมาตรฐาน)
model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  type      LeaveType   @default(PERSONAL_LEAVE)

  documentUrl String?
  approverId  String?
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@map("core_leave_requests")
}

// 🌟 ตารางตั้งค่า "กะการทำงาน"
model WorkShift {
  id             String         @id @default(uuid())
  name           String         @unique
  code           String         @unique
  startTime      String
  endTime        String
  lateThreshold  Int            @default(15)
  otStartTime    String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  attendanceType AttendanceType @default(ONSITE)

  users        User[]         @relation("UserShift")
  attendances  Attendance[]
  WorkSchedule WorkSchedule[]

  @@map("core_work_shifts")
}

// 🌟 ตารางบันทึกเวลาเข้า-ออก
model Attendance {
  id              String           @id @default(uuid())
  date            DateTime         @db.Date
  checkInTime     DateTime?
  checkOutTime    DateTime?
  checkInLocation String?
  checkInPhotoUrl String?
  status          AttendanceStatus @default(ABSENT)
  type            AttendanceType   @default(PRESENT)
  lateMinutes     Int              @default(0)
  otHours         Float            @default(0)
  isManualEdit    Boolean          @default(false)

  userId String
  user   User   @relation("UserAttendance", fields: [userId], references: [id])

  shiftId String
  shift   WorkShift @relation(fields: [shiftId], references: [id])

  recordedById String?
  recordedBy   User?   @relation("RecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("core_attendances")
}

model WorkSchedule {
  id      String   @id @default(uuid())
  userId  String
  shiftId String
  date    DateTime @db.Date
  status  String   @default("PLANNED") // PLANNED, COMPLETED, CANCELLED

  user  User      @relation(fields: [userId], references: [id])
  shift WorkShift @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("core_work_schedules")
}

model OtRequest {
  id           String      @id @default(uuid())
  userId       String
  date         DateTime    @db.Date
  plannedHours Float
  actualHours  Float?
  reason       String
  status       LeaveStatus @default(PENDING)
  approverId   String?

  user     User  @relation("UserOTRequests", fields: [userId], references: [id])
  approver User? @relation("OTApprover", fields: [approverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_ot_requests")
}

model hrDocument {
  id          String      @id @default(uuid())
  name        String // ชื่อเอกสาร เช่น "ใบรับรองแพทย์", "ใบ กว."
  description String? // รายละเอียดเพิ่มเติม
  type        hrDocType   @default(PERSONAL)
  status      hrDocStatus @default(ACTIVE)

  // 🔗 ความสัมพันธ์: เอกสารนี้เป็นของใคร? (ถ้าเป็นเอกสารบริษัท ให้ใส่เป็น null ได้)
  userId String?
  user   User?   @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)

  // 🔗 ความสัมพันธ์: 1 แฟ้ม มีไฟล์แนบได้หลายไฟล์
  files hrDocumentFile[]

  sortOrder Int @default(0) // 🌟 ลำดับการแสดงผล

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_documents")
}

// 🌟 2. ตารางย่อย: ไฟล์เอกสารที่อัปโหลด (เก็บ URL และวันหมดอายุ)
model hrDocumentFile {
  id String @id @default(uuid())

  // 🔗 ความสัมพันธ์: ไฟล์นี้อยู่ในแฟ้มเอกสารไหน?
  documentId String
  document   hrDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  fileUrl    String    @map("file") // ลิงก์ไฟล์ที่ได้จากระบบอัปโหลด
  fileName   String? // ชื่อไฟล์ต้นฉบับ
  category   String? // หมวดหมู่ย่อย
  expireDate DateTime? @db.Date // 🌟 สำคัญมาก: เอาไว้แจ้งเตือนเอกสารหมดอายุ

  isVerified Boolean @default(false) // HR ตรวจสอบความถูกต้องแล้วหรือยัง?
  remark     String?

  // 🔗 ใครเป็นคนกดอัปโหลดไฟล์นี้เข้าระบบ? (เผื่อตามตัวคนอัปโหลดผิด)
  uploadedById String?
  uploadedBy   User?   @relation("DocumentUploader", fields: [uploadedById], references: [id])

  sortOrder Int @default(0) // 🌟 ลำดับการแสดงผลภายในแฟ้ม

  // 🔗 ไฟล์นี้เป็นของพนักงานคนไหน? (ส่วนใหญ่จะตรงกับเจ้าของ documentId)
  userId String?
  user   User?   @relation("UserFiles", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_document_files")
}

// 🌟 Enums สำหรับควบคุมข้อมูลให้อยู่ในกรอบ
enum hrDocType {
  PERSONAL // เอกสารส่วนตัว (บัตรปชช, ทะเบียนบ้าน)
  CERTIFICATION // ใบรับรอง/ใบอนุญาต (ใบ กว., จป., Work Permit)
  MEDICAL // ใบรับรองแพทย์ / ประกันสังคม
  CONTRACT // สัญญาจ้างงาน
  COMPANY_POLICY // เอกสารนโยบายบริษัท (ส่วนกลาง)
}

enum hrDocStatus {
  ACTIVE
  ARCHIVED
  EXPIRED
}

// =========================================
// 💰 PHASE 5: Payroll & Deductions (ระบบเงินเดือน)
// =========================================
model Payslip {
  id          String @id @default(uuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodMonth String

  // Earnings
  baseSalary      Float
  commission      Float @default(0)
  otAmount        Float @default(0)
  incentive       Float @default(0)
  mobileAllowance Float @default(0)
  otherEarnings   Float @default(0)

  // Deductions
  ssoDeduction    Float @default(0)
  guaranteeRetain Float @default(0)
  taxDeduction    Float @default(0)
  leaveDeduction  Float @default(0)
  otherDeductions Float @default(0)

  otherDetails Json?
  remarks      String?

  // Summary
  totalEarnings   Float
  totalDeductions Float
  netIncome       Float

  status PayslipStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_payslips") // 🌟 เพิ่ม @@map
}

model PayrollConfig {
  id                String @id @default(uuid())
  ssoRateEmployee   Float  @default(5.0)
  ssoRateCompany    Float  @default(5.0)
  ssoMaxBase        Float  @default(15000)
  whtRateDaily      Float  @default(3.0)
  otRateNormal      Float  @default(1.5)
  otRateHoliday     Float  @default(3.0)
  latePenaltyPerMin Float  @default(5.0)

  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("hrm_payroll_configs") // 🌟 เพิ่ม @@map
}

model EmployeeCompensation {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentType PayType
  baseWage    Float

  // 🌟 เพิ่มฟิลด์เรท OT เหมาจ่ายที่หายไป
  fixedOtRatePerHour Float? // ถ้าระบุ (เช่น 50) ระบบจะใช้เรทนี้คิด OT แทนการคำนวณตามสัดส่วนกฎหมาย

  fixedAllowance Float   @default(0)
  deductSso      Boolean @default(true)
  deductTax      Boolean @default(true)

  @@map("hrm_employee_compensations") // 🌟 เพิ่ม @@map
}

// 🌟 ตารางประวัติการปรับขึ้นเงินเดือน
model SalaryAdjustment {
  id String @id @default(uuid())

  userId String
  user   User   @relation("UserSalaryHistory", fields: [userId], references: [id], onDelete: Cascade)

  oldWage Float
  newWage Float

  reason        String
  effectiveDate DateTime @db.Date

  status String @default("PENDING")

  approvedById String?
  approver     User?   @relation("SalaryApprover", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_salary_adjustments")
}

enum PayType {
  MONTHLY
  DAILY
  PER_PROJECT
}

model PayrollDeduction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  amount    Float
  reason    String
  refNumber String?

  status      DeductionStatus @default(PENDING)
  targetMonth String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_payroll_deductions") // 🌟 เพิ่ม @@map
}

model PayrollEarning {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  amount    Float
  reason    String
  refNumber String?

  status      EarningStatus @default(PENDING)
  targetMonth String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_payroll_earnings")
}

