generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 👑 หมวด ALPHA & OMEGA (Core Structure & RBAC)
// ============================================================================

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  roles        JobRole[]
  userProfiles UserProfile[]

  @@map("core_departments")
}

model JobLine {
  id        String    @id @default(uuid())
  name      String    @unique
  code      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  roles     JobRole[]

  @@map("core_job_lines")
}

model JobRole {
  id     String @id @default(uuid())
  name   String @unique
  prefix String @unique
  level  Int    @default(10)

  departmentId String?
  jobLineId    String?

  // --- ระบบลำดับชั้น (Hierarchy) ---
  parentRoleId   String? // ID ของตำแหน่งหัวหน้า
  parentRole     JobRole?  @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  assistantRoles JobRole[] @relation("RoleHierarchy")

  department   Department?   @relation(fields: [departmentId], references: [id])
  jobLine      JobLine?      @relation(fields: [jobLineId], references: [id])
  permissions  Permission[]
  userProfiles UserProfile[]
  users        User[]

  @@map("core_job_roles")
}

model Permission {
  id        String  @id @default(uuid())
  roleId    String
  menuId    String
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)
  role      JobRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("core_permissions")
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  email        String?    @unique
  status       UserStatus @default(ACTIVE)
  roleId       String

  profile UserProfile?
  role    JobRole      @relation(fields: [roleId], references: [id])

  // Relations การทำธุรกรรมต่างๆ
  attendances      Attendance[]
  projects         Project[]         @relation("ProjectManager")
  tasks            Task[]            @relation("TaskAssignee")
  leaveRequests    LeaveRequest[]
  purchaseRequests PurchaseRequest[] @relation("PRRequester") // เติมชื่อ Relation ให้ตรงกัน

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_users")
}

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taxId           String  @unique @db.VarChar(13)
  firstName       String
  lastName        String
  telephoneNumber String  @unique @db.VarChar(10)
  lineId          String?

  addressDetail String
  subdistrictId Int?
  districtId    Int?
  provinceId    Int?
  zipcode       String? @db.VarChar(5)

  departmentId String
  roleId       String
  image        String?

  department  Department   @relation(fields: [departmentId], references: [id])
  role        JobRole      @relation(fields: [roleId], references: [id])
  province    Province?    @relation(fields: [provinceId], references: [id])
  district    District?    @relation(fields: [districtId], references: [id])
  subdistrict Subdistrict? @relation(fields: [subdistrictId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_user_profiles")
}

// ============================================================================
// 📍 หมวด MASTER DATA (ข้อมูลที่อยู่ประเทศไทย)
// ============================================================================

model Province {
  id           Int           @id
  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  districts    District[]
  userProfiles UserProfile[]

  @@map("provinces")
}

model District {
  id         Int      @id
  provinceId Int      @map("province_id")
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  subdistricts Subdistrict[]
  userProfiles UserProfile[]

  @@map("districts")
}

model Subdistrict {
  id         Int      @id
  districtId Int      @map("district_id")
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  nameTh       String        @map("name_th")
  nameEn       String?       @map("name_en")
  lat          Float?
  lng          Float?        @map("long")
  zipcode      Int?
  userProfiles UserProfile[]

  @@map("subdistricts")
}

// ============================================================================
// 👥 หมวด HRM (บุคคลและการเข้างาน)
// ============================================================================

model Attendance {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date        DateTime       @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  type        AttendanceType @default(PRESENT)
  locationLat Float?
  locationLng Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_attendances")
}

model LeaveRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      LeaveType   @default(PERSONAL_LEAVE)
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String
  status    LeaveStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hrm_leave_requests")
}

// ============================================================================
// 🏗️ หมวด OPERATIONS (ระบบโปรเจกต์และงานหน้าไซต์)
// ============================================================================

model Project {
  id       String        @id @default(uuid())
  code     String        @unique
  name     String
  location String?
  status   ProjectStatus @default(PLANNING)

  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  tasks            Task[]
  siteReports      DailySiteReport[]
  purchaseRequests PurchaseRequest[]

  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("ops_projects")
}

model Task {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title  String
  status TaskStatus @default(TODO)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("ops_tasks")
}

model DailySiteReport {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  reportDate  DateTime @db.Date
  weather     String?
  workerCount Int      @default(0)
  progress    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ops_daily_site_reports")
}

// ============================================================================
// 🛒 หมวด PROCUREMENT (จัดซื้อและคลังสินค้า)
// ============================================================================

model PurchaseRequest {
  id       String         @id @default(uuid())
  prNumber String         @unique
  status   DocumentStatus @default(DRAFT)

  // เชื่อมกับโปรเจกต์และผู้ขอ
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  requesterId String
  requester   User   @relation("PRRequester", fields: [requesterId], references: [id])

  items   Json
  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pro_purchase_requests")
}

// ============================================================================
// 🔴 ENUMS (สถานะทั้งหมดในระบบ)
// ============================================================================

enum UserStatus {
  ACTIVE // ใช้งาน
  INACTIVE // ไม่ใช้งาน
  SUSPENDED // ระงับการใช้งาน
  ON_LEAVE // ลา
  RESIGNED // ลาออก
  TERMINATED // เลิกจ้าง
  LOCKED // ล็อค
  PENDING //รอสถานะ
}

enum AttendanceType {
  PRESENT //มาทำงาน
  LATE //สาย
  ABSENT //ขาดงาน
  LEAVE //ลา
  HALFDAY //ครึ่งวัน
  OVERTIME //โอที
  HOLIDAY //วันหยุด
  WFH //ทำงานที่บ้าน
  ONSITE //ทำงานนอกสถานที่
}

enum LeaveType {
  SICK_LEAVE //ลาป่วย
  PERSONAL_LEAVE //ลากิจ
  ANNUAL_LEAVE //ลาพักร้อน
  MATERNITY //ลาคลอด
  ORDINATION //ลาบวช
  UNPAID_LEAVE //ลาไม่มีเงินเดือน
}

enum LeaveStatus {
  DRAFT // ร่าง
  PENDING // รออนุมัติ
  APPROVED // อนุมัติ
  REJECTED // ไม่อนุมัติ
  CANCELLED // ยกเลิก
}

enum ProjectStatus {
  BIDDING // กำลังประมูล
  PLANNING // กำลังวางแผน
  IN_PROGRESS // กำลังดำเนินการ
  ON_HOLD // หยุดชั่วคราว
  HANDOVER // ส่งมอบงาน
  WARRANTY // รับประกัน
  COMPLETED // เสร็จสิ้น
  CANCELLED // ยกเลิก
}

enum TaskStatus {
  TODO // ยังไม่เริ่ม
  IN_PROGRESS // กำลังดำเนินการ
  BLOCKED // ติดปัญหา
  IN_REVIEW // กำลังตรวจสอบ
  REWORK // ต้องแก้ไข
  DONE // เสร็จสิ้น
}

enum DefectStatus {
  REPORTED // แจ้ง
  INSPECTING // ตรวจสอบ
  FIXING // แก้ไข
  RESOLVED // แก้ไขแล้ว
  REJECTED // ปฏิเสธ
  CLOSED // ปิด
}

enum DocumentStatus {
  DRAFT // ร่าง
  WAITING_APPROVAL // รออนุมัติ
  APPROVED // อนุมัติ
  REVISED // แก้ไข
  REJECTED // ปฏิเสธ
  ORDERING // กำลังสั่งซื้อ
  PARTIAL_RECEIVED // รับบางส่วน
  COMPLETED // เสร็จสิ้น
  CANCELLED // ยกเลิก
}
